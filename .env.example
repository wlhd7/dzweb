# Flask app configuration
FLASK_APP=dzweb
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here
DZWEB_ADMIN_PASSWORD=admin123

# Mail configuration
MAIL_SERVER=smtp.exmail.qq.com
MAIL_PORT=465
MAIL_USE_TLS=False
MAIL_USE_SSL=True
MAIL_USERNAME=noreply@dongzhen.cn
MAIL_PASSWORD=your-mail-password
MAIL_DEFAULT_SENDER=Guangzhou Dongzhen <noreply@dongzhen.cn>
MAIL_ADMIN=info@dongzhen.cn

# SEO configuration
BAIDU_PUSH_TOKEN=your-baidu-token-here
BAIDU_SITE_VERIFICATION=your-baidu-verification-code
BAIDU_TONGJI_ID=your-baidu-tongji-id
BING_SITE_VERIFICATION=your-bing-verification-code
GOOGLE_SITE_VERIFICATION=your-google-verification-code
